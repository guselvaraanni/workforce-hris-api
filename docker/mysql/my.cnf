# =============================================================================
# docker/mysql/my.cnf — Custom MySQL configuration
# Mounted read-only into the MySQL container.
#
# WHY: Django's mysqlclient requires utf8mb4 for full Unicode support.
# The default MySQL charset in older images is latin1 which corrupts emoji
# and multi-byte characters in employee name/bio fields.
# =============================================================================

[mysqld]
# Character encoding — must match Django's OPTIONS.charset = 'utf8mb4'
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci

# Enable strict mode — matches Django's SET sql_mode='STRICT_TRANS_TABLES'
sql_mode              = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

# InnoDB settings for HRIS workload
innodb_buffer_pool_size     = 256M    # Cache frequently accessed data pages
innodb_log_file_size        = 64M     # Larger log files = fewer disk flushes
innodb_flush_log_at_trx_commit = 1   # 1 = full ACID (safe); 2 = faster but risks 1s data loss
innodb_lock_wait_timeout    = 50      # Seconds before select_for_update() gives up

# Connection pool
max_connections             = 200     # Tune based on Gunicorn workers × threads
wait_timeout                = 600     # Must be >= Django CONN_MAX_AGE (600s)
interactive_timeout         = 600

# Slow query log — helps identify unoptimised queries in development
slow_query_log              = 1
slow_query_log_file         = /var/lib/mysql/slow.log
long_query_time             = 1       # Log queries taking > 1 second

[client]
default-character-set = utf8mb4

[mysql]
default-character-set = utf8mb4
